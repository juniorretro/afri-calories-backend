{
  "name": "afri-calories-backend",
  "version": "1.0.0",
  "engines": {
    "node": "18.x"
  },
  "description": "API Backend pour l'application de suivi de calories africaines",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "build": "node node_modules/.bin/prisma generate",
    "db:generate": "node node_modules/.bin/prisma generate",
    "db:migrate": "node node_modules/.bin/prisma migrate deploy",
    "db:seed": "node src/prisma/seed.js",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "prisma": "^5.7.0"
  }
}
